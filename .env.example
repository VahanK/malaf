NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose in client bundles (docs/SECURITY.md B6).
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=https://work-withme.com

# Tier-1 USDT watcher (Sprint 3). CRON_SECRET must match the value configured
# in Vercel's cron settings — Vercel sends it as `Authorization: Bearer <secret>`.
# TRONGRID_API_KEY is optional (raises TronGrid's free-tier rate limit; a free
# key works at https://www.trongrid.io).
CRON_SECRET=
TRONGRID_API_KEY=
